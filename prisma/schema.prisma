generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum IssueStatus {
  todo
  in_progress
  done
}

enum IssuePriority {
  low
  medium
  high
}

model Project {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
  issues      Issue[]
}

model User {
  id             String   @id @default(uuid())
  name           String
  email          String   @unique
  createdAt      DateTime @default(now())
  assignedIssues Issue[]
  comments       Comment[]
}

model Label {
  id        String   @id @default(uuid())
  name      String   @unique
  createdAt DateTime @default(now())
  issues    Issue[]
}

model Issue {
  id         String        @id @default(uuid())
  projectId  String
  assigneeId String?
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee   User?         @relation(fields: [assigneeId], references: [id], onDelete: SetNull)
  labels     Label[]
  comments   Comment[]
  title      String
  description String?
  priority   IssuePriority @default(medium)
  status     IssueStatus   @default(todo)
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt

  @@index([projectId])
  @@index([assigneeId])
}

model Comment {
  id        String   @id @default(uuid())
  issueId   String
  authorId  String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([issueId])
  @@index([authorId])
}
